# 이 파일을 application-local.properties로 복사한 뒤 개인 로컬 DB 설정을 입력
spring.datasource.url=jdbc:mysql://localhost:3306/mingpark_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
spring.datasource.username=${DB_USERNAME:ming}
spring.datasource.password=${DB_PASSWORD:ming}

# 로컬 개발 환경에서는 엔티티 변경을 반영하고 실행 SQL을 확인
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.show-sql=true
